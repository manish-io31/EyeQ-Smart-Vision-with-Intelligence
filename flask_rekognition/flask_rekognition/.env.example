# ════════════════════════════════════════════════════════════════
# SurveillanceAI — Environment Configuration Template
# Copy this file to .env and fill in your values
#   cp .env.example .env
# ════════════════════════════════════════════════════════════════

# ── Flask ────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-strong-random-secret
DEBUG=false

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./surveillance.db

# ── Detection Thresholds ─────────────────────────────────────────
DETECTION_CONFIDENCE_THRESHOLD=55
ALERT_CONFIDENCE_THRESHOLD=75
ALERT_COOLDOWN_SECONDS=30

# ── Twilio SMS (get free at twilio.com) ──────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Your mobile number (alerts sent here) ────────────────────────
ADMIN_PHONE_NUMBER=+91XXXXXXXXXX

# ── Email Alerts (optional) ──────────────────────────────────────
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
ADMIN_EMAIL=your_email@gmail.com

# ── AWS Rekognition (optional — YOLO is used if not set) ─────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── YOLO model path ──────────────────────────────────────────────
YOLO_MODEL_PATH=../detection/models/yolov8n.pt
